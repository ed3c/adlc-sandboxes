# python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# os
.DS_Store

# SECRETS — never commit credentials/tokens to this public mirror.
# (The sandcastle-orchestration Path-A run uses a Claude OAuth token; it lives in a THROWAWAY repo's
#  sandcastle config OUTSIDE this mirror and must NEVER be uploaded — no auth tokens of any kind.)
.env
.env.*
*.env
.sandcastle/
**/.sandcastle/
*token*.json
*credentials*
*secret*
*.pem
*.key

# sandbox runtime artifacts (state dirs keep only .gitkeep + their own .gitignore)
sandboxes/*/state/*
!sandboxes/*/state/.gitkeep
!sandboxes/*/state/.gitignore

# generated trace outputs from running selftests (the committed *-fold-in-gate.record.json stay tracked)
sandboxes/*/trace/*selftest*

# runtime artifacts written by live probes (data/production output — not part of the repo)
data/
