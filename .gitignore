# python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# os
.DS_Store

# sandbox runtime artifacts (state dirs keep only .gitkeep + their own .gitignore)
sandboxes/*/state/*
!sandboxes/*/state/.gitkeep
!sandboxes/*/state/.gitignore

# generated trace outputs from running selftests (the committed *-fold-in-gate.record.json stay tracked)
sandboxes/*/trace/*selftest*

# runtime artifacts written by live probes (northstar data/production layout — not part of the mirror)
data/
